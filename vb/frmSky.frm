Attribute VB_Name = "frmSky"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = True
Attribute VB_Exposed = False
Option Explicit

Dim j

Rem Red Choper Declaration
Dim xDest As Double, yDest As Double                    'Position of Red choper
Dim aniCounter As Byte                                  'Holds no of Frame for Animation of Red Choper

Rem Atacking Choper Declaration
Dim xAC(10) As Double, yAC(10) As Double                'Position of Attacing Choper
Dim aniACCnt(10) As Integer                             'Holds no of Frame for Animation of Atacking Choper
Dim AttackingChoperCnt As Integer                        'Holds no of Atacking Choper Released
Dim Release As Boolean

Rem Bullet Declaration
Dim xBullet(10) As Double, yBullet(10) As Double        'Position of Bullets
Dim BulletCnt As Integer                                'Holds Number of Bullet Released

Dim ForLoopz As Integer
Dim ForLoopc As Integer
Dim RandNo As Byte

Rem Blast
Dim Blast As Boolean
Dim aniBlastCnt As Integer
Dim xBlast As Double, yBlast As Double

Rem After Blast
Dim BlastACCnt As Integer
Dim aniABlastCnt(10) As Integer
Dim xABlast(10) As Double, yABlast(10) As Double

Rem Showing Red Chopper
Dim DontShowRC As Boolean
Dim DontMoveRC As Boolean

Rem Score
Dim Total As Integer, Hit As Integer

Private Sub Form_KeyDown(KeyCode As Integer, Shift As Integer)
    If DontMoveRC = False Then
        If KeyCode = 37 Then
            xDest = xDest - 7
        ElseIf KeyCode = 38 Then
            yDest = yDest - 7
        ElseIf KeyCode = 39 Then
            xDest = xDest + 7
        ElseIf KeyCode = 40 Then
            yDest = yDest + 7
        ElseIf KeyCode = 32 Then
            If BulletCnt >= 10 Then Exit Sub
            xBullet(BulletCnt) = xDest + 100
            yBullet(BulletCnt) = yDest + 45
            BulletCnt = BulletCnt + 1
        End If
    End If
    If KeyCode = 27 Then
        ShowCursor (True)
        End
    End If
    
End Sub

Private Sub Form_Load()
    Show
    ShowCursor (False)
    BulletCnt = 0
    aniCounter = 0
    aniBlastCnt = 0
    Dim i As Integer
    For i = 0 To 10
        xAC(i) = 800
    Next
    Do
    DoEvents
        Cls
        Rem Red Choper
        If DontShowRC = False Then
            j = BitBlt(Me.hDC, xDest, yDest, 130, 55, MaskChoper(aniCounter).hDC, 0, 0, vbSrcAnd)
            j = BitBlt(Me.hDC, xDest, yDest, 130, 55, picChoper(aniCounter).hDC, 0, 0, vbSrcPaint)
            aniCounter = aniCounter + 1
            If aniCounter >= 4 Then aniCounter = 1
        End If
        Rem Increasing Attacking Chopper
        If Release = True Then
            Release = False
            If AttackingChoperCnt >= 10 Then GoTo NoMore:
            AttackingChoperCnt = AttackingChoperCnt + 1
            yAC(AttackingChoperCnt - 1) = Int(Rnd * (50 + 400))
        End If
NoMore:
        Rem Moving Attacking Chopper
        For ForLoopz = 0 To AttackingChoperCnt - 1
            j = BitBlt(Me.hDC, xAC(ForLoopz), yAC(ForLoopz), 75, 34, MaskAC(aniACCnt(ForLoopz)).hDC, 0, 0, vbSrcAnd)
            j = BitBlt(Me.hDC, xAC(ForLoopz), yAC(ForLoopz), 75, 34, AC(aniACCnt(ForLoopz)).hDC, 0, 0, vbSrcPaint)
            aniACCnt(ForLoopz) = aniACCnt(ForLoopz) + 1
            If aniACCnt(ForLoopz) > 1 Then aniACCnt(ForLoopz) = 0
            xAC(ForLoopz) = xAC(ForLoopz) - 10
        Next
        If xAC(0) + 100 < 0 Then
            AttackingChoperCnt = AttackingChoperCnt - 1
            For ForLoopc = 1 To AttackingChoperCnt
                xAC(ForLoopc - 1) = xAC(ForLoopc)
                yAC(ForLoopc - 1) = yAC(ForLoopc)
            Next
            xAC(AttackingChoperCnt) = 800
        End If

        Rem Bullet Movement
        For ForLoopz = 0 To BulletCnt - 1
            j = BitBlt(Me.hDC, xBullet(ForLoopz), yBullet(ForLoopz), 50, 20, MaskBullet.hDC, 0, 0, vbSrcAnd)
            j = BitBlt(Me.hDC, xBullet(ForLoopz), yBullet(ForLoopz), 50, 20, picBullet.hDC, 0, 0, vbSrcPaint)
            xBullet(ForLoopz) = xBullet(ForLoopz) + 30
            If xBullet(ForLoopz) >= Me.ScaleWidth Then
                BulletCnt = BulletCnt - 1
                For ForLoopc = 1 To BulletCnt
                    xBullet(ForLoopc - 1) = xBullet(ForLoopc)
                    yBullet(ForLoopc - 1) = yBullet(ForLoopc)
                Next
            End If
        Next
        
        For ForLoopz = 0 To BulletCnt - 1
            For ForLoopc = 0 To AttackingChoperCnt - 1
                If xBullet(ForLoopz) > xAC(ForLoopc) And xBullet(ForLoopz) < xAC(ForLoopc) + 75 And yBullet(ForLoopz) < yAC(ForLoopc) + 34 And yBullet(ForLoopz) > yAC(ForLoopc) Then
                    Hit = Hit + 1
                    BlastACCnt = BlastACCnt + 1
                    xABlast(BlastACCnt - 1) = xAC(ForLoopc)
                    yABlast(BlastACCnt - 1) = yAC(ForLoopc) - 25
                    Rem Attacking Choper
                    For i = ForLoopc To AttackingChoperCnt - 2
                        xAC(i) = xAC(i + 1)
                        yAC(i) = yAC(i + 1)
                    Next
                    AttackingChoperCnt = AttackingChoperCnt - 1
                    xAC(AttackingChoperCnt) = 800
                    Rem Bullet
                    For i = ForLoopz To BulletCnt - 2
                        xBullet(i) = xBullet(i + 1)
                        yBullet(i) = yBullet(i + 1)
                    Next
                    BulletCnt = BulletCnt - 1
                End If
            Next
        Next
        
        Rem Hit by Attacking Chopper
        For ForLoopc = 0 To AttackingChoperCnt - 1
            If xAC(ForLoopc) < xDest + 110 And xAC(ForLoopc) > xDest And yAC(ForLoopc) > yDest And yAC(ForLoopc) < yDest + 55 Then
                Blast = True
                DontMoveRC = True
                xBlast = xDest + 100
                yBlast = yDest + 35
                For i = ForLoopc To AttackingChoperCnt - 2
                    xAC(i) = xAC(i + 1)
                    yAC(i) = yAC(i + 1)
                Next
                AttackingChoperCnt = AttackingChoperCnt - 1
                xAC(AttackingChoperCnt) = 800
            ElseIf xAC(ForLoopc) < xDest + 110 And xAC(ForLoopc) > xDest And yAC(ForLoopc) + 45 > yDest And yAC(ForLoopc) + 45 < yDest + 55 Then
                Blast = True
                xBlast = xDest + 100
                yBlast = yDest + 15
                For i = ForLoopc To AttackingChoperCnt - 2
                    xAC(i) = xAC(i + 1)
                    yAC(i) = yAC(i + 1)
                Next
                AttackingChoperCnt = AttackingChoperCnt - 1
                xAC(AttackingChoperCnt) = 800
            End If
        Next
        
        Rem Blast Red Chopper
        If Blast = True Then
            j = BitBlt(Me.hDC, xBlast - (picBlast(aniBlastCnt).Width / 2), yBlast - (picBlast(aniBlastCnt).Height / 2), MaskBlast(aniBlastCnt).Width, MaskBlast(aniBlastCnt).Height, MaskBlast(aniBlastCnt).hDC, 0, 0, vbSrcAnd)
            j = BitBlt(Me.hDC, xBlast - (picBlast(aniBlastCnt).Width / 2), yBlast - (picBlast(aniBlastCnt).Height / 2), picBlast(aniBlastCnt).Width, picBlast(aniBlastCnt).Height, picBlast(aniBlastCnt).hDC, 0, 0, vbSrcPaint)
            aniBlastCnt = aniBlastCnt + 1
            If aniBlastCnt >= 12 Then DontShowRC = True
            If aniBlastCnt >= 17 Then
                aniBlastCnt = 0
                Blast = False
                xDest = -130
                yDest = -55
                frmLast.lbltotal.Caption = "Total : " & Total
                frmLast.lblHit.Caption = "Hit : " & Hit
                frmLast.lblMissed.Caption = "Missed : " & Total - Hit
                frmLast.Show 1
            End If
        End If
        
        Rem Blasting Attacking Chopper
        For i = 0 To BlastACCnt - 1
            j = BitBlt(Me.hDC, xABlast(i), yABlast(i), MaskGotAC(aniABlastCnt(i)).Width, MaskGotAC(aniABlastCnt(i)).Height, MaskGotAC(aniABlastCnt(i)).hDC, 0, 0, vbSrcAnd)
            j = BitBlt(Me.hDC, xABlast(i), yABlast(i), picGotAC(aniABlastCnt(i)).Width, picGotAC(aniABlastCnt(i)).Height, picGotAC(aniABlastCnt(i)).hDC, 0, 0, vbSrcPaint)
            aniABlastCnt(i) = aniABlastCnt(i) + 1
            If aniABlastCnt(i) >= 17 Then
                aniABlastCnt(i) = 0
                Dim DecNum As Integer
                BlastACCnt = BlastACCnt - 1
                For DecNum = i To BlastACCnt - 1
                    xABlast(DecNum) = xABlast(DecNum + 1)
                    yABlast(DecNum) = yABlast(DecNum + 1)
                Next
            End If
        Next
    Loop
End Sub

Private Sub tmrACReleaser_Timer()
    Release = True
    Total = Total + 1
End Sub

